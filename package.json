{
  "name": "newsletter-ai",
  "version": "1.0.0",
  "description": "AI-powered newsletter processor that extracts article links, reads content, and generates audio-friendly summaries",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/mcp/index.ts",
    "run:mcp": "tsx src/mcp/index.ts",
    "build": "tsc",
    "init:claude": "node scripts/init-claude.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "settings": "cd settings && pnpm run dev:api & cd settings && pnpm dev"
  },
  "keywords": [
    "newsletter",
    "ai",
    "gmail",
    "summarization"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@extractus/article-extractor": "^8.0.20",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@types/js-yaml": "^4.0.9",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21",
    "mailparser": "^3.7.5",
    "node-imap": "^0.9.6",
    "p-limit": "^7.2.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.9.1",
    "@types/node-imap": "^0.9.3",
    "@vitest/ui": "^4.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.1"
  }
}